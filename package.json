{
  "name": "axera-fca",
  "version": "0.0.2",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./min": {
      "types": "./dist/esm/min/index.d.ts",
      "import": "./dist/esm/min/index.js",
      "require": "./dist/cjs/min/index.js"
    },
    "./min/*": {
      "import": "./dist/esm/min/*.js",
      "require": "./dist/cjs/min/*.js"
    },
    "./esm": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./esm/min": {
      "types": "./dist/esm/min/index.d.ts",
      "import": "./dist/esm/min/index.js"
    },
    "./esm/*": {
      "types": "./dist/esm/*.d.ts",
      "import": "./dist/esm/*.js"
    },
    "./cjs": {
      "require": "./dist/cjs/index.js"
    },
    "./cjs/min": {
      "require": "./dist/cjs/min/index.js"
    },
    "./cjs/*": {
      "require": "./dist/cjs/*.js"
    },
    "./api/*": {
      "import": "./dist/esm/api/*.js",
      "require": "./dist/cjs/api/*.js"
    }
  },
  "scripts": {
    "postinstall": "node scripts/verify-axera.js",
    "build": "tsup && node scripts/generate-manifests.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "chalk": "^5.6.2",
    "gradient-string": "^3.0.0",
    "http-cookie-agent": "^7.0.3",
    "https-proxy-agent": "^9.0.0",
    "keytar": "^7.9.0",
    "mqtt": "^5.15.1",
    "picocolors": "^1.1.1",
    "qs": "^6.15.1",
    "tough-cookie": "^6.0.1",
    "undici": "^7.25.0",
    "websocket-stream": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/qs": "^6.15.0",
    "glob": "^13.0.6",
    "madge": "^8.0.0",
    "terser": "^5.47.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
