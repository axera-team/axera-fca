{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "types": ["node"],
  },
  "include": ["src/**/*", "node_modules/@types/**/*", "api/listenMqtt.js"],
  "exclude": ["src/apis/*", "src/api/*"]
}